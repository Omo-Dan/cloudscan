# ── DATABASE (XAMPP MySQL) ────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=cloudscan
DB_PORT=3306

# ── EMAIL ALERTS (Gmail SMTP) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ADD_YOUR_GMAIL_HERE
SMTP_PASS=ADD_YOUR_APP_PASSWORD_HERE
ALERT_EMAIL=ADD_YOUR_EMAIL_HERE

# ── APP ───────────────────────────────────────
APP_NAME=CloudScan
APP_VERSION=1.0.0
APP_ENV=development
REPORTS_FOLDER=storage/reports
LOG_FILE=logs/activity.log